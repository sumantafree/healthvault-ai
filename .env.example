# ============================================================
# HealthVault AI — Environment Variables
# Copy to .env and fill in values — NEVER commit .env
# ============================================================

# App
APP_ENV=development          # development | staging | production
APP_NAME="HealthVault AI"
APP_VERSION=1.0.0
SECRET_KEY=your-256-bit-secret-key-here
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Supabase
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Storage (Supabase Storage / S3)
STORAGE_PROVIDER=supabase        # supabase | s3
SUPABASE_BUCKET_REPORTS=health-reports
SUPABASE_BUCKET_PRESCRIPTIONS=prescriptions
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1

# AI / LLM
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4-turbo-preview
GEMINI_API_KEY=
AI_PROVIDER=openai              # openai | gemini

# OCR
TESSERACT_CMD=/usr/bin/tesseract   # path to tesseract binary

# WhatsApp (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Redis (optional — for caching/task queue)
REDIS_URL=redis://localhost:6379/0

# Logging
LOG_LEVEL=INFO
